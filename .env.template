# =========================
# Traefik
# =========================
TRAEFIK_ACME_EMAIL=admin@example.com

# =========================
# Public domains
# =========================
SHOP_DOMAIN=example.com
SHOP_DOMAIN_WWW=www.example.com
# Escape dots for Traefik redirect regex, example: www\.example\.com
SHOP_DOMAIN_WWW_ESCAPED=www\.example\.com
API_DOMAIN=api.example.com

# =========================
# Database
# =========================
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change-me
POSTGRES_DB=medusa
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_DB}?ssl_mode=disable

# =========================
# Redis
# =========================
REDIS_URL=redis://redis:6379

# =========================
# Medusa secrets
# =========================
JWT_SECRET=replace-with-a-long-random-string
COOKIE_SECRET=replace-with-a-long-random-string

# =========================
# Medusa URLs and CORS
# =========================
STORE_CORS=https://example.com,https://www.example.com
ADMIN_CORS=https://api.example.com
AUTH_CORS=https://example.com,https://www.example.com,https://api.example.com
ADMIN_URL=https://api.example.com/app
MEDUSA_BACKEND_URL=https://api.example.com
STOREFRONT_URL=https://example.com

# =========================
# Medusa admin bootstrap
# =========================
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change-me

# =========================
# Traefik admin access control
# =========================
ADMIN_ALLOWED_IPS=127.0.0.1/32

# =========================
# Storefront build-time variables
# =========================
NEXT_PUBLIC_BASE_URL=https://example.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.example.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key
NEXT_PUBLIC_DEFAULT_REGION=fr
REVALIDATE_SECRET=replace-with-a-long-random-string
